generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  passwordHash  String
  latitude          Float?
  longitude         Float?
  locationName      String?
  calculationMethod Int       @default(1)
  asrTiming         Int       @default(0) // 0 = Earlier Asr, 1 = Later Asr
  hijriOffset       Int       @default(0)
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  transactions      Transaction[]
  goals             Goal[]
  spiritualHabits   SpiritualHabit[]
  spiritualDayLogs  SpiritualDayLog[]
  journalEntries    JournalEntry[]
  dailyTasks        DailyTask[]
  persons           Person[]
  weekendTasks      WeekendTask[]
  notes             Note[]
  fitnessLogs       FitnessLog[]
  recurringTrackers RecurringTracker[]
  duas              Dua[]
  books             Book[]
  relapseLogs       RelapseLog[]
  documents         Document[]
  bookFolders       BookFolder[]
  documentFolders   DocumentFolder[]
  timeTable         TimeTable?
}


enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          Int             @id @default(autoincrement())
  userId      Int
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    String          @db.VarChar(50)
  type        TransactionType @default(EXPENSE)
  date        DateTime        @default(now()) @db.Date
  createdAt   DateTime        @default(now()) @db.Timestamptz()
}

enum GoalCategory {
  RELIGIOUS
  CAREER
  FINANCES
  HEALTH
  PERSONAL
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Goal {
  id          Int          @id @default(autoincrement())
  userId      Int
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  category    GoalCategory @default(PERSONAL)
  priority    GoalPriority @default(MEDIUM)
  progress    Int          @default(0) // 0 to 100
  targetDate  DateTime?    @db.Date
  isCompleted Boolean      @default(false)
  reminders   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @db.Timestamptz()
}

model SpiritualHabit {
  id        Int                 @id @default(autoincrement())
  userId    Int
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String              
  isPrayer  Boolean             @default(false)
  createdAt DateTime            @default(now()) @db.Timestamptz()
  logs      SpiritualHabitLog[]

  @@unique([userId, name])
}

model SpiritualHabitLog {
  id          Int            @id @default(autoincrement())
  habitId     Int
  habit       SpiritualHabit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date        DateTime       @db.Date
  isCompleted Boolean        @default(false)
  prayedWithJamaat Boolean   @default(false)
  createdAt   DateTime       @default(now()) @db.Timestamptz()

  @@unique([habitId, date])
}

model SpiritualDayLog {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime @db.Date
  quranMemorization String?  @db.Text
  otherActivities   String?  @db.Text
  createdAt         DateTime @default(now()) @db.Timestamptz()

  @@unique([userId, date])
}

enum JournalCategory {
  OFFICE
  LEARNING
  MISC
}

model JournalEntry {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String          @db.Text
  category  JournalCategory
  subject   String?
  project   String?
  ticketId  String?
  workType  String?
  duration  String?
  location  String?
  activity  String?
  tag       String?
  date      DateTime        @default(now()) @db.Date
  createdAt DateTime        @default(now()) @db.Timestamptz()
}

model DailyTask {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean   @default(false)
  targetDate  DateTime? @db.Date
  category    String    @default("TODAY")
  createdAt   DateTime  @default(now()) @db.Timestamptz()
}

enum DebtType {
  CREDIT // Money I lend to others
  DEBIT  // Money I borrow from others
}

enum DebtStatus {
  PENDING
  PAID
}

model Person {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String       
  createdAt DateTime     @default(now()) @db.Timestamptz()
  debts     DebtRecord[]

  @@unique([userId, name])
}

model DebtRecord {
  id           Int           @id @default(autoincrement())
  personId     Int
  amount       Decimal       @db.Decimal(10, 2)
  type         DebtType
  date         DateTime      @default(now()) @db.Date
  status       DebtStatus    @default(PENDING)
  notes        String?       @db.Text
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  
  person       Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model WeekendTask {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  logs            WeekendTaskLog[]
}

model WeekendTaskLog {
  id            Int         @id @default(autoincrement())
  weekendTaskId Int
  date          DateTime    @default(now()) @db.Date
  weekStartDate DateTime    @db.Date
  
  task          WeekendTask @relation(fields: [weekendTaskId], references: [id], onDelete: Cascade)
  
  @@unique([weekendTaskId, weekStartDate])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model FitnessLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity  String   // e.g., 'Running', 'Gym', 'Walking', 'Cycling', 'Yoga', 'Swimming', 'Other'
  duration  Int      // Workout duration in minutes
  distance  Decimal? @db.Decimal(5, 2) // Optional distance in kilometers
  notes       String?  @db.Text
  muscleGroup String?
  date        DateTime @default(now()) @db.Date // Workout date
  createdAt DateTime @default(now()) @db.Timestamptz()
}

model RecurringTracker {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   
  lastDone  DateTime? @db.Date
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@unique([userId, title])
}

enum DuaCategory {
  PERSONAL
  FAMILY
  CAREER
  GENERAL
}

model Dua {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     String      @db.Text
  translation String?     @db.Text
  category    DuaCategory @default(PERSONAL)
  createdAt   DateTime    @default(now()) @db.Timestamptz()
}

model BookFolder {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz()
  books     Book[]

  @@unique([userId, name])
}

model Book {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId  Int?
  folder    BookFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title     String
  author    String?
  driveLink String?     @db.Text
  notes     String?     @db.Text
  date      DateTime    @default(now()) @db.Date
  createdAt DateTime    @default(now()) @db.Timestamptz()
}

model DocumentFolder {
  id        Int        @id @default(autoincrement())
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now()) @db.Timestamptz()
  documents Document[]

  @@unique([userId, name])
}

model Document {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId  Int?
  folder    DocumentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title     String
  link      String          @db.Text
  notes     String?         @db.Text
  date      DateTime        @default(now()) @db.Date
  createdAt DateTime        @default(now()) @db.Timestamptz()
}

model RelapseLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now()) @db.Timestamptz()
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz()
}

model TimeTable {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wakeUpTime            String   @default("05:00")
  tillSunrise           String   @default("Dua, Adhkar & Fajr Prayer")
  sunriseTillOffice     String   @default("Recitation, Study & Breakfast")
  officeDeparture       String   @default("08:30")
  officeReturn          String   @default("17:30")
  gymPreference         String   @default("NONE") // NONE, AFTER_FAJR, BEFORE_OFFICE, MAGHRIB_TO_ISHA, AFTER_ISHA
  maghribToIsha         String   @default("Spiritual reading, family time")
  ishaToHifz            String   @default("Isha prayer and Quran review")
  hifzClassTime         String   @default("22:00")
  sleepTime             String   @default("22:30")
  createdAt             DateTime @default(now()) @db.Timestamptz()
  updatedAt             DateTime @updatedAt @db.Timestamptz()
}
