generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          Int             @id @default(autoincrement())
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    String          @db.VarChar(50)
  type        TransactionType @default(EXPENSE)
  date        DateTime        @default(now()) @db.Date
  createdAt   DateTime        @default(now()) @db.Timestamptz()
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Goal {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  period      GoalPeriod   @default(MONTHLY)
  priority    GoalPriority @default(MEDIUM)
  progress    Int          @default(0) // 0 to 100
  targetDate  DateTime?    @db.Date
  isCompleted Boolean      @default(false)
  isArchived  Boolean      @default(false)
  reminders   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @db.Timestamptz()
}

model SpiritualHabit {
  id        Int                 @id @default(autoincrement())
  name      String              @unique
  isPrayer  Boolean             @default(false)
  createdAt DateTime            @default(now()) @db.Timestamptz()
  logs      SpiritualHabitLog[]
}

model SpiritualHabitLog {
  id          Int            @id @default(autoincrement())
  habitId     Int
  habit       SpiritualHabit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date        DateTime       @db.Date
  isCompleted Boolean        @default(false)
  prayedWithJamaat Boolean   @default(false)
  createdAt   DateTime       @default(now()) @db.Timestamptz()

  @@unique([habitId, date])
}

model SpiritualDayLog {
  id                Int      @id @default(autoincrement())
  date              DateTime @unique @db.Date
  quranMemorization String?  @db.Text
  otherActivities   String?  @db.Text
  createdAt         DateTime @default(now()) @db.Timestamptz()
}

enum JournalCategory {
  OFFICE
  LEARNING
  MISC
}

model JournalEntry {
  id        Int             @id @default(autoincrement())
  content   String          @db.Text
  category  JournalCategory
  date      DateTime        @default(now()) @db.Date
  createdAt DateTime        @default(now()) @db.Timestamptz()
}

model DailyTask {
  id          Int      @id @default(autoincrement())
  title       String
  isCompleted Boolean  @default(false)
  targetDate  DateTime @db.Date
  createdAt   DateTime @default(now()) @db.Timestamptz()
}

enum DebtType {
  CREDIT // Money I lend to others
  DEBIT  // Money I borrow from others
}

enum DebtStatus {
  PENDING
  PAID
}

model Person {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  createdAt DateTime     @default(now()) @db.Timestamptz()
  debts     DebtRecord[]
}

model DebtRecord {
  id           Int           @id @default(autoincrement())
  personId     Int
  amount       Decimal       @db.Decimal(10, 2)
  type         DebtType
  date         DateTime      @default(now()) @db.Date
  status       DebtStatus    @default(PENDING)
  notes        String?       @db.Text
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  
  person       Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model WeekendTask {
  id              Int       @id @default(autoincrement())
  title           String
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  logs            WeekendTaskLog[]
}

model WeekendTaskLog {
  id            Int         @id @default(autoincrement())
  weekendTaskId Int
  date          DateTime    @default(now()) @db.Date
  weekStartDate DateTime    @db.Date
  
  task          WeekendTask @relation(fields: [weekendTaskId], references: [id], onDelete: Cascade)
  
  @@unique([weekendTaskId, weekStartDate])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model FitnessLog {
  id        Int      @id @default(autoincrement())
  activity  String   // e.g., 'Running', 'Gym', 'Walking', 'Cycling', 'Yoga', 'Swimming', 'Other'
  duration  Int      // Workout duration in minutes
  distance  Decimal? @db.Decimal(5, 2) // Optional distance in kilometers
  notes     String?  @db.Text
  date      DateTime @default(now()) @db.Date // Workout date
  createdAt DateTime @default(now()) @db.Timestamptz()
}

model RecurringTracker {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  lastDone  DateTime? @db.Date
  createdAt DateTime @default(now()) @db.Timestamptz()
}
