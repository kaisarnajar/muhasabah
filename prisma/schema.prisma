generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          Int             @id @default(autoincrement())
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    String          @db.VarChar(50)
  type        TransactionType @default(EXPENSE)
  date        DateTime        @default(now()) @db.Date
  createdAt   DateTime        @default(now()) @db.Timestamptz()
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Goal {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      @db.Text
  period      GoalPeriod   @default(MONTHLY)
  priority    GoalPriority @default(MEDIUM)
  progress    Int          @default(0) // 0 to 100
  targetDate  DateTime?    @db.Date
  isCompleted Boolean      @default(false)
  isArchived  Boolean      @default(false)
  reminders   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @db.Timestamptz()
}

model ReligiousActivity {
  id                 Int      @id @default(autoincrement())
  date               DateTime @unique @default(now()) @db.Date
  fajr               Boolean  @default(false)
  dhuhr              Boolean  @default(false)
  asr                Boolean  @default(false)
  maghrib            Boolean  @default(false)
  isha               Boolean  @default(false)
  quranReading       Boolean  @default(false)
  adhkar             Boolean  @default(false)
  quranMemorization  String?  @db.Text
  createdAt          DateTime @default(now()) @db.Timestamptz()
}

enum JournalCategory {
  OFFICE
  LEARNING
  MISC
}

model JournalEntry {
  id        Int             @id @default(autoincrement())
  content   String          @db.Text
  category  JournalCategory
  date      DateTime        @default(now()) @db.Date
  createdAt DateTime        @default(now()) @db.Timestamptz()
}

model DailyTask {
  id          Int      @id @default(autoincrement())
  title       String
  isCompleted Boolean  @default(false)
  targetDate  DateTime @db.Date
  createdAt   DateTime @default(now()) @db.Timestamptz()
}

enum DebtType {
  CREDIT // Money I lend to others
  DEBIT  // Money I borrow from others
}

enum DebtStatus {
  PENDING
  PAID
}

model Person {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  createdAt DateTime     @default(now()) @db.Timestamptz()
  debts     DebtRecord[]
}

model DebtRecord {
  id           Int           @id @default(autoincrement())
  personId     Int
  amount       Decimal       @db.Decimal(10, 2)
  type         DebtType
  date         DateTime      @default(now()) @db.Date
  status       DebtStatus    @default(PENDING)
  notes        String?       @db.Text
  createdAt    DateTime      @default(now()) @db.Timestamptz()
  
  person       Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model WeekendTask {
  id              Int       @id @default(autoincrement())
  title           String
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  logs            WeekendTaskLog[]
}

model WeekendTaskLog {
  id            Int         @id @default(autoincrement())
  weekendTaskId Int
  date          DateTime    @default(now()) @db.Date
  weekStartDate DateTime    @db.Date
  
  task          WeekendTask @relation(fields: [weekendTaskId], references: [id], onDelete: Cascade)
  
  @@unique([weekendTaskId, weekStartDate])
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}
